# macOS
.DS_Store

# Secrets (App Store Connect API Key / certificates)
# ローカルでのみ保持し、CI へは GitHub Secrets 経由で渡す
key/
*.p8
*.p12
*.mobileprovision
*.cer

# Flutter build artifacts (サブディレクトリ内の build/ も除外)
**/build/

# Firebase
# google-services.json / GoogleService-Info.plist / firebase_options_*.dart は
# Firebase の API キーを含むがクライアントに配布される公開情報であり、機密ではない。
# 実際のセキュリティ境界は Firestore / Storage Rules と App Check で担保する。
# https://firebase.google.com/docs/projects/api-keys
# したがってこれらはリポジトリにコミットする方針。
.firebase/
firebase-debug.log
firestore-debug.log
ui-debug.log
