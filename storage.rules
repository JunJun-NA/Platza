rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    // ユーザー所有の写真: 本人のみアクセス可
    match /users/{uid}/{allPaths=**} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
    }

    // それ以外は全拒否
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
